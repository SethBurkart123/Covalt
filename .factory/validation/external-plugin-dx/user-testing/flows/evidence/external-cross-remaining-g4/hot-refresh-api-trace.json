{
  "namespace": "utv_ext_g4",
  "pluginId": "utv_ext_g4_hot_echo",
  "nodeType": "utv_ext_g4_hot_echo:echo",
  "steps": [
    {
      "command": "uninstall_node_provider_plugin",
      "status": "error",
      "response": "HTTP Error 400: Bad Request"
    },
    {
      "command": "import_node_provider_plugin_from_directory",
      "status": 200,
      "response": "{\"result\":{\"id\":\"utv_ext_g4_hot_echo\"}}"
    },
    {
      "command": "list_node_provider_definitions (after install)",
      "status": 200,
      "response": "{\"result\":{\"definitions\":[{\"type\":\"utv_ext_g4_hot_echo:echo\",\"name\":\"utv_ext_g4 Hot Echo\",\"description\":\"utv_ext_g4 hot refresh node\",\"category\":\"data\",\"icon\":\"circle\",\"executionMode\":\"flow\",\"parameters\":[{\"id\":\"value\",\"label\":\"Value\",\"type\":\"text\",\"required\":false,\"default\":\"utv_ext_g4_hot_default\"}],\"capabilities\":{\"execute\":true,\"materialize\":false,\"configureRuntime\":false,\"routes\":false},\"route\":null,\"source\":\"provider\",\"providerId\":\"utv_ext_g4_hot_echo\",\"pluginId\":\"utv_ext_g4_hot_echo\"}]}}"
    },
    {
      "command": "enable_node_provider_plugin(false)",
      "status": 200,
      "response": "{\"result\":{\"success\":true,\"enabled\":false}}"
    },
    {
      "command": "list_node_provider_definitions (after disable)",
      "status": 200,
      "response": "{\"result\":{\"definitions\":[]}}"
    },
    {
      "command": "enable_node_provider_plugin(true)",
      "status": 200,
      "response": "{\"result\":{\"success\":true,\"enabled\":true}}"
    },
    {
      "command": "list_node_provider_definitions (after re-enable)",
      "status": 200,
      "response": "{\"result\":{\"definitions\":[{\"type\":\"utv_ext_g4_hot_echo:echo\",\"name\":\"utv_ext_g4 Hot Echo\",\"description\":\"utv_ext_g4 hot refresh node\",\"category\":\"data\",\"icon\":\"circle\",\"executionMode\":\"flow\",\"parameters\":[{\"id\":\"value\",\"label\":\"Value\",\"type\":\"text\",\"required\":false,\"default\":\"utv_ext_g4_hot_default\"}],\"capabilities\":{\"execute\":true,\"materialize\":false,\"configureRuntime\":false,\"routes\":false},\"route\":null,\"source\":\"provider\",\"providerId\":\"utv_ext_g4_hot_echo\",\"pluginId\":\"utv_ext_g4_hot_echo\"}]}}"
    },
    {
      "command": "uninstall_node_provider_plugin",
      "status": 200,
      "response": "{\"result\":{\"success\":true}}"
    },
    {
      "command": "list_node_provider_definitions (after uninstall)",
      "status": 200,
      "response": "{\"result\":{\"definitions\":[]}}"
    }
  ]
}