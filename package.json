{
  "name": "covalt-desktop",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "backend": "uv run main.py",
    "generate:runtime-events": "bun scripts/generate-runtime-events.ts",
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:desktop": "bun run electrobun:build && concurrently \"bun run dev:frontend\" \"bun run electrobun:dev\"",
    "dev:frontend": "vite",
    "dev:backend": "COVALT_DEV_MODE=1 COVALT_GENERATE_TS=1 uv run main.py",
    "electrobun:dev": "ELECTROBUN_DEV=1 ELECTROBUN_PROJECT_ROOT=\"$PWD\" electrobun dev",
    "electrobun:build": "electrobun build",
    "build": "vite build",
    "build:frontend": "vite build",
    "build:backend": "uv run --group dev pyinstaller --noconfirm --clean --onedir --name covalt-backend --distpath backend/dist --workpath backend/build --specpath backend/build --add-data \"$PWD/nodes:nodes\" --collect-submodules nodes --collect-submodules zynk --collect-submodules agno --collect-submodules sqlalchemy --collect-submodules backend --collect-submodules tiktoken_ext --collect-data zynk --collect-data tiktoken --collect-data litellm --additional-hooks-dir \"$PWD/backend/pyinstaller-hooks\" --hidden-import tiktoken_ext.openai_public --hidden-import uvicorn.logging --hidden-import uvicorn.lifespan.on --hidden-import uvicorn.protocols.http --hidden-import uvicorn.protocols.http.auto --hidden-import uvicorn.protocols.websockets.auto main.py",
    "build:desktop": "bun run build:frontend && bun run build:backend && bun run electrobun:build",
    "start": "vite preview --port 4096",
    "lint": "eslint .",
    "lint:python": "uv run --group dev ruff check backend/ tests/ main.py",
    "lint:python:fix": "uv run --group dev ruff check --fix backend/ tests/ main.py",
    "lint:python:report": "python3 scripts/ruff_debt_report.py --advisory --inventory tests/artifacts/lint-python-debt-inventory.json",
    "ci:lint-python:report": "bun run lint:python:report",
    "test": "vitest",
    "test:run": "bun run ci:full",
    "test:e2e": "playwright test",
    "test:e2e:reuse": "PLAYWRIGHT_SERVER_MODE=reuse playwright test",
    "test:e2e:exclusive": "PLAYWRIGHT_SERVER_MODE=exclusive playwright test",
    "test:e2e:list": "playwright test --list",
    "playwright:install": "playwright install chromium",
    "ci:lint": "bun run lint",
    "ci:vitest": "bun run test --run",
    "ci:pytest": "uv run pytest -q",
    "ci:playwright": "bun run test:e2e:exclusive",
    "ci:full": "bun run ci:lint && bun run ci:vitest && bun run ci:pytest && bun run ci:playwright"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@chenglou/pretext": "^0.0.7",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.6.13",
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.1.20",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.11",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.4",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/core": "3.20.0",
    "@tiptap/extension-code-block-lowlight": "3.20.0",
    "@tiptap/extension-document": "3.20.0",
    "@tiptap/extension-history": "3.20.0",
    "@tiptap/extension-image": "3.20.0",
    "@tiptap/extension-link": "3.20.0",
    "@tiptap/extension-list": "3.20.0",
    "@tiptap/extension-mathematics": "3.20.0",
    "@tiptap/extension-paragraph": "3.20.0",
    "@tiptap/extension-placeholder": "3.20.0",
    "@tiptap/extension-table": "3.20.0",
    "@tiptap/extension-text": "3.20.0",
    "@tiptap/markdown": "3.20.0",
    "@tiptap/pm": "3.20.0",
    "@tiptap/react": "3.20.0",
    "@tiptap/starter-kit": "3.20.0",
    "@tiptap/suggestion": "3.20.0",
    "@types/lodash": "^4.17.16",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "3.2.7",
    "effect": "^3.21.2",
    "electrobun": "1.18.1",
    "fflate": "^0.8.2",
    "frimousse": "^0.3.0",
    "fuse.js": "^7.1.0",
    "hast-util-to-html": "^9.0.5",
    "html-to-image": "^1.11.13",
    "idiomorph": "^0.7.4",
    "json-schema-to-typescript": "^15.0.4",
    "katex": "0.16.22",
    "lodash": "^4.17.21",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.563.0",
    "md4w": "^0.2.7",
    "motion": "^12.38.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.5.4",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.32",
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tailwindcss": "^4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.18"
  }
}
